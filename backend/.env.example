# Copy this file to .env and fill in your values

# --- Database ---
DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/evoxu_db

# --- JWT ---
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-very-long-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- App ---
BASE_URL=https://11-11-11.shop

# --- Admin ---
# Send this key in header: X-Admin-Key
ADMIN_SECRET_KEY=your-admin-secret-key-change-this
